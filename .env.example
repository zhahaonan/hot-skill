# hot-creator 配置文件
# 复制此文件为 .env 并填入你的值
# 仅独立运行 Python 脚本时需要（作为 Cursor/Claude Code Skill 使用时不需要配置）

# AI 模型配置（用于 trend_analyze / content_brief / industry_insight / product_profile）
AI_API_KEY=sk-your-api-key-here
AI_MODEL=deepseek/deepseek-chat
# AI_API_BASE=https://api.deepseek.com/v1  # 可选，自定义端点

